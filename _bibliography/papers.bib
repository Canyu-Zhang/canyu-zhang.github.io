@inproceedings{zhang2026infoflow,
  abbr        = {ICML},
  bibtex_show = {true},
  title       = {InfoFlow KV: Information-Flow-Aware KV Recomputation for Long Context},
  author      = {Zhang, Canyu and Wang, Shengjie and Zhou, Tianyi and Zhuo, Danyang},
  booktitle   = {International Conference on Machine Learning (ICML 2026)},
  year        = {2026},
  note        = {*Co-first author},
  abstract    = {We propose InfoFlow KV, a chunk-based KV prefilling and recomputation pipeline enabling reusable KV caches and recovering cross-chunk attention under long-context inference across multiple LLMs. We introduce two information-flow-aware recomputation strategies: a query-conditioned attention-norm token selection method and a chunk reordering scheme that improves prompt-context interaction, achieving +6% F1 on HotpotQA over prior methods.},
  selected    = {true}
}

@article{zhang2025subcp,
  abbr        = {preprint},
  bibtex_show = {true},
  title       = {Submodular Context Partitioning and Compression for In-Context Learning},
  author      = {Zhang, Canyu and Wang, Shengjie and Zhou, Tianyi},
  year        = {2025},
  abstract    = {We study Sub-CP, a block-aware context selection framework for in-context learning that leverages submodular objectives to balance global diversity and local coherence across demonstration context blocks. We achieve up to +7.1% average F1 score over baseline partition methods and +15.4% F1 score on TREC.},
  selected    = {true}
}

@inproceedings{zhang2026sage,
  abbr        = {ACL},
  bibtex_show = {true},
  title       = {SAGE: Benchmarking and Improving Retrieval for Deep Research Agents},
  author      = {Zhang, Canyu and Zhao, Chen},
  booktitle   = {Annual Meeting of the Association for Computational Linguistics (ACL 2026)},
  year        = {2026},
  abstract    = {We build SAGE, a benchmark for reasoning-intensive scientific literature retrieval with 1,200 queries across four domains and a 200K-paper corpus. We evaluate six deep research agents under both web search and corpus retrieval settings, and propose a corpus-level test-time scaling framework that improves retrieval accuracy by +8% (short-form) and +2% (open-ended).},
  selected    = {true}
}


